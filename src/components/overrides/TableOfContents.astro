---
import Default from "@astrojs/starlight/components/TableOfContents.astro";
---

<div class="tb-container bg-[var(--sl-color-bg-elevated)] pr-4">
	<Default />
</div>

<style is:global>
	.tb-container {
		padding-bottom: 1rem;
	}

	/* ── The Header ("On this page") ── */
	.tb-container h2#starlight__on-this-page {
		color: var(--sl-color-white) !important;
		font-size: var(--sl-text-h5) !important;
		font-weight: 600 !important;
		line-height: var(--sl-line-height-headings) !important;
		margin-bottom: 0.5rem !important;
		text-wrap: balance;
	}

	/* ── The Active Track (The Vertical Line) ── */
	.tb-container nav > ul {
		margin: 0 !important;
		padding: 0 !important;
		display: flex;
		flex-direction: column;
		border-left: 2px solid var(--sidebar-border) !important;
		list-style: none !important;
	}

	.tb-container ul ul {
		border-left: none !important;
		margin: 0 !important;
		padding: 0 !important;
		list-style: none !important;
	}

	.tb-container ul li {
		margin: 0 !important;
		padding: 0 !important;
	}

	/* ── The Links & Indentation ── */
	.tb-container ul a {
		position: relative;
		display: block !important;
		padding: 0.375rem 0.5rem !important;
		line-height: 1.3 !important;
		font-size: 13px !important;
		text-decoration: none !important;
		color: var(--sidebar-text) !important;
		transition: all 150ms ease-out !important;
		border-radius: 0 !important;

		padding-left: calc(1.25rem + (1rem * var(--depth, 0))) !important;
		margin-left: -2px !important;

		border-left: 2px solid transparent !important;
	}

	.tb-container ul a[style*="--depth: 0"] {
		color: var(--sidebar-text) !important;
		font-weight: 400 !important;
	}

	/* Hover state */
	.tb-container ul a:hover {
		border-left-color: var(--sidebar-border-hover) !important;
		color: var(--sidebar-text-strong) !important;
	}

	/* Active state — Orbbit teal instead of CF orange */
	.tb-container ul a[aria-current="true"] {
		border-left-color: var(--orbbit-primary) !important;
		color: var(--sidebar-text-strong) !important;
		font-weight: 500 !important;
		background-color: transparent !important;
	}

	@media (prefers-reduced-motion: reduce) {
		.tb-container * {
			transition: none !important;
		}
	}
</style>
